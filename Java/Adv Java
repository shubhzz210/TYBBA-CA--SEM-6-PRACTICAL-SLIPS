      import java.sql.*;
import java.util.Scanner;

public class StudentData
{
    public static void main(String args[])
    {
        Scanner sc = new Scanner(System.in);

        try
        {
            // Load Driver
            Class.forName("com.mysql.cj.jdbc.Driver");

            // Connection
            Connection con = DriverManager.getConnection(
                "jdbc:mysql://localhost:3306/test", "root", "root");

            // Insert Query
            String insertQuery = "INSERT INTO Student VALUES (?, ?, ?)";
            PreparedStatement ps = con.prepareStatement(insertQuery);

            // Accept at least 5 records
            for(int i = 1; i <= 5; i++)
            {
                System.out.println("\nEnter details of student " + i);

                System.out.print("Roll No: ");
                int rno = sc.nextInt();
                sc.nextLine();

                System.out.print("Name: ");
                String name = sc.nextLine();

                System.out.print("Percentage: ");
                double per = sc.nextDouble();

                ps.setInt(1, rno);
                ps.setString(2, name);
                ps.setDouble(3, per);

                ps.executeUpdate();
            }

            // Find highest percentage
            String query = "SELECT * FROM Student WHERE per = (SELECT MAX(per) FROM Student)";
            PreparedStatement ps2 = con.prepareStatement(query);

            ResultSet rs = ps2.executeQuery();

            System.out.println("\nStudent with Highest Percentage:\n");

