import java.applet.Applet;
import java.awt.*;
import java.lang.Thread;

public class TrafficSignalApplet extends Applet implements Runnable
{
    Thread t;
    int state = 0; // 0 = Red, 1 = Green, 2 = Yellow

    public void init()
    {
        t = new Thread(this);
        t.start();
    }

    public void run()
    {
        try
        {
            while(true)
            {
                state = 0; // Red
                repaint();
                Thread.sleep(3000);

                state = 1; // Green
                repaint();
                Thread.sleep(3000);

                state = 2; // Yellow
                repaint();
                Thread.sleep(2000);
            }
        }
        catch(Exception e)
        {
            System.out.println(e);
        }
    }

    public void paint(Graphics g)
    {
        // Draw signal box
        g.setColor(Color.black);
        g.fillRect(100, 50, 80, 220);

        // Red Light
        if(state == 0)
            g.setColor(Color.red);
        else
            g.setColor(Color.gray);
        g.fillOval(120, 60, 40, 40);

        // Yellow Light
        if(state == 2)
            g.setColor(Color.yellow);
        else
            g.setColor(Color.gray);
        g.fillOval(120, 120, 40, 40);

        // Green Light
        if(state == 1)
            g.setColor(Color.green);
        else
            g.setColor(Color.gray);
        g.fillOval(120, 180, 40, 40);
    }
}
